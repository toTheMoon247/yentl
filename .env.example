# Local secrets for the dev environment.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Used by ad-hoc commands such as `supabase db push` when run with:
#
#   set -a && source .env && set +a && supabase db push
#
# Never put production secrets here. Use a real secret manager for prod.

# Database password for the dev Supabase project (set when the project was created).
SUPABASE_DB_PASSWORD=
